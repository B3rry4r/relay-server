{
  "name": "relay",
  "description": "Relay terminal server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "nodemon --watch 'src/**' --watch 'docs/**' --ext 'ts,md,json' --exec 'npm run build && node dist/src/index.js'",
    "build": "rm -rf dist && tsc",
    "start": "npm run build && node dist/src/index.js",
    "test": "vitest run --dir test"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "http-proxy": "^1.18.1",
    "marked": "^18.0.2",
    "node-pty": "npm:@homebridge/node-pty-prebuilt-multiarch@^0.13.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/http-proxy": "^1.17.17",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.0",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.1",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
